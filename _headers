# ─────────────────────────────────────────────────────────────
#  SUPER RESELLS — security headers (Cloudflare Pages reads this file)
#
#  These protect the site from common "for fun" attacks: clickjacking
#  (embedding the store in a fake page), MIME sniffing, content/script
#  injection, referrer leakage, and abuse of browser features.
#
#  The safe headers apply to EVERY page. The stricter Content-Security-
#  Policy is applied to the public storefront pages only — NOT /admin,
#  which needs broader access to run the Store Manager (Sveltia CMS).
# ─────────────────────────────────────────────────────────────

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Keep the admin dashboard out of search results (it's harmless to load —
# nobody can change anything without your private GitHub token).
/admin/*
  X-Robots-Tag: noindex

# Content-Security-Policy for the storefront pages.
# Allows: this site, inline scripts/styles the pages use, Google Fonts,
# and order/contact form posts to Formspree. Blocks everything else,
# and forbids the site from being embedded in a frame (anti-clickjacking).
/
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io; object-src 'none'

/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io; object-src 'none'

